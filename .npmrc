# @westenets/* packages are published to GitHub Packages, not the public npm registry.
# Auth: place a PAT with read:packages in ~/.npmrc (developers) or set
# the GITHUB_PACKAGES_TOKEN env var and add the line below at deploy time:
#   //npm.pkg.github.com/:_authToken=${GITHUB_PACKAGES_TOKEN}
@westenets:registry=https://npm.pkg.github.com

# We intentionally don't auto-install peer deps. We only consume the web subset
# of @westenets/dvai-bridge-* (core/react/vanilla); their optional native peers
# (@westenets/dvai-bridge-capacitor, @mlc-ai/web-llm, etc.) are not published
# nor needed here. We declare exactly the runtime peers we use.
auto-install-peers=false
