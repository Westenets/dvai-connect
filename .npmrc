# @dvai-bridge/* packages now ship from the public npm registry — no scope
# mapping needed. Previously these were consumed via a forked GitHub Packages
# mirror (@westenets/*) which had peerDependenciesMeta-stripping issues; the
# public-npm publish at v4.0.2+ preserves optional peer markers correctly.

# Avoid auto-installing optional peer deps. dvai-bridge declares optional
# peers (@dvai-bridge/capacitor for native mobile, @mlc-ai/web-llm for the
# WebLLM backend, llama-cpp-capacitor for native llama.cpp). The meet web app
# only uses the transformers.js backend, so we explicitly do NOT install
# these optional peers.
auto-install-peers=false
